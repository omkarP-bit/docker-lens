{
  "name": "docker-lens",
  "version": "0.1.0",
  "description": "Read-only Docker introspection SDK & CLI — containers, ports, images, stats, networks, volumes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docker-lens": "bin/docker-lens.js"
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["docker", "cli", "devtools", "dashboard", "ports", "containers"],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/dockerode": "^3.3.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "chalk": "4.1.2",
    "cli-table3": "^0.6.0",
    "commander": "^11.0.0",
    "dockerode": "^4.0.0"
  }
}
